<!DOCTYPE html>
<html>
<head>
  <title>My Store</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/" class="logo">My Store</a>
    <div class="links">
      <a href="/cart">🛒 Cart<% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %></a>
      <% if (session.user) { %>
        <span>Hi, <%= session.user.name %></span>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>

  <div class="container">
    <h1>Our Products</h1>
    <input type="text" id="searchInput" class="search-bar" placeholder="🔍 Search products..." onkeyup="filterProducts()">

    <div class="grid">
      <% products.forEach(function(p, index) { %>
        <div class="card" data-name="<%= p.name %>">
          <% if (index < 2) { %><span class="badge-new">NEW</span><% } %>
          <a href="/product/<%= p._id %>" class="card-link">
            <img src="<%= p.image %>" alt="<%= p.name %>">
            <div class="card-name"><%= p.name %></div>
            <div class="price">₹<%= p.price %></div>
          </a>
          <form action="/cart/add/<%= p._id %>" method="POST" class="quick-add-form">
            <button type="submit" class="quick-add-btn">Add to Cart</button>
          </form>
        </div>
      <% }); %>
    </div>
  </div>

  <script>
    function filterProducts() {
      const query = document.getElementById('searchInput').value.toLowerCase();
      document.querySelectorAll('.card').forEach(function(card) {
        const name = card.getAttribute('data-name').toLowerCase();
        card.style.display = name.includes(query) ? '' : 'none';
      });
    }
  </script>
  <script src="/toast.js"></script>
  <script src="/chatbot.js"></script>
</body>
</html>